# Docker ignore file for Lissabon Azulejo Tile Generator

# Git
.git
.gitignore

# Development files
*.md
LICENSE
README*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Build artifacts (if any)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Test files that shouldn't be in production
test-*.js
test-*.html

# Temporary files
*.tmp
*.temp
